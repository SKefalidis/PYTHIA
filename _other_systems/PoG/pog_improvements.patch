+            return []
+        
+        top_list_str = match.group(1)
+        
+        # 提取所有的数字
+        numbers = re.findall(r'\b\d+\b', top_list_str)
+        
+        # 转换为 int 并返回
+        return list(map(int, numbers))
+
+        match = re.search(r'top_entity:\s*\{([^}]+)\}', text)
