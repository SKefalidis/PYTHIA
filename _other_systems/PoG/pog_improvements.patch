+    def Beam_search_step3(NL_CoT_all_paths, version, total_id_to_name_dict, query_sentence, top_k_value = 3):
+        
+        print('''
+            +++++++++++++++++++++   Path beam search: step3 - Path Selection     +++++++++++++++++++++
