+def check_pog_server(server_url: str, timeout: int = 3) -> bool:
+    health_url = f"{server_url}/health"
+    try:
+        response = requests.get(health_url, timeout=timeout)
+        return response.status_code == 200
+    except requests.RequestException:
+        return False
