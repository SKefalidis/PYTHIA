+    def extract_entities_from_strings(paths):
+        # 创建一个字典来存储实体 ID 和名称
+        entities_dict = {}
+
+        # 正则表达式用于匹配实体
+        # entity_pattern = r'\{(m\.\w+): ([^,}]+)'
+        entity_pattern = r'(m\.\w+): ([^,}]+)'
+
+        # 遍历每个路径字符串
+        for path in paths:
+            # 使用正则表达式找到所有匹配的实体
+            entities = re.findall(entity_pattern, path)
+            
+            # 将实体添加到字典中
+            for entity_id, name in entities:
+                entities_dict[entity_id] = name.strip()
+
+        return entities_dict
+
